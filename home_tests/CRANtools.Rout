CRAN__> details <- CRAN_check_details()

CRAN__> ## Available variables:
CRAN__> names(details)
[1] "Package"    "Version"    "Flavor"     "Check"      "Status"    
[6] "Output"     "Flags"      "Maintainer"

CRAN__> ## Tabulate checks according to their status:
CRAN__> tab <- with(details, table(Check, Status))

CRAN__> ## Inspect some installation problems:
CRAN__> bad <- subset(details,
CRAN__+               ((Check == "whether package can be installed") &
CRAN__+                (Status != "OK")))

CRAN__> ## Show a random sample of up to 6
CRAN__> head(bad[sample(seq_len(NROW(bad)), NROW(bad)), ])
